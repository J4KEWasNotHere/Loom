										<string name="Name">getTweenRatio</string>
										<int64 name="SourceAssetId">-1</int64>
										<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
										<UniqueId name="UniqueId">43081bf106ede6b70a69856100003e18</UniqueId>
