							<string name="Name">trove</string>
							<int64 name="SourceAssetId">-1</int64>
							<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
							<UniqueId name="UniqueId">3e60f5073f8033070a6cbd00000161fa</UniqueId>
